# ─── Banco de Dados ──────────────────────────────────────────────────────────
# Formato: postgresql://usuario:senha@host:porta/nome_do_banco
DATABASE_URL="postgresql://postgres:postgres@localhost:5432/fintrack"

# ─── JWT ─────────────────────────────────────────────────────────────────────
# OBRIGATÓRIO: mínimo 32 caracteres em cada secret
# Gere com: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
JWT_SECRET="substitua-por-uma-string-aleatoria-de-pelo-menos-32-chars"
JWT_REFRESH_SECRET="substitua-por-outra-string-diferente-de-pelo-menos-32-chars"

# ─── Servidor ────────────────────────────────────────────────────────────────
NODE_ENV="development"
PORT=3333
FRONTEND_URL="http://localhost:5173"

# ─── OAuth — Google ──────────────────────────────────────────────────────────
# Obtenha em: https://console.cloud.google.com → APIs & Services → Credentials
GOOGLE_CLIENT_ID="seu-client-id.apps.googleusercontent.com"
GOOGLE_CLIENT_SECRET="seu-client-secret"
GOOGLE_REDIRECT_URI="http://localhost:3333/auth/google/callback"

# ─── OAuth — GitHub ──────────────────────────────────────────────────────────
# Obtenha em: https://github.com/settings/developers → OAuth Apps
GITHUB_CLIENT_ID="seu-github-client-id"
GITHUB_CLIENT_SECRET="seu-github-client-secret"
GITHUB_REDIRECT_URI="http://localhost:3333/auth/github/callback"

# ─── Rate Limiting (opcionais — têm defaults sensatos) ───────────────────────
RATE_LIMIT_MAX=100
RATE_LIMIT_WINDOW_MS=60000
AUTH_RATE_LIMIT_MAX=10
AUTH_RATE_LIMIT_WINDOW_MS=900000
