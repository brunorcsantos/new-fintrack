// ─── Configuração ─────────────────────────────────────────────────────────────
// O datasource diz ao Prisma onde está o banco.
// A URL vem do .env para nunca ficar hardcoded no código.
datasource db {
  provider = "postgresql"
  url= env("DATABASE_URL")
}

// O generator define o que o "prisma generate" vai produzir.
// O client padrão gera o Prisma Client TypeScript tipado.
generator client {
  provider = "prisma-client-js"
}

// ─── Enums ────────────────────────────────────────────────────────────────────
// Enums no Prisma garantem que apenas valores válidos entram no banco.
// Evita bugs silenciosos como "expense" vs "Expense" vs "EXPENSE".

enum TxType {
  income
  expense
}

enum Frequency {
  monthly
  yearly
}

enum RecurringMode {
  indefinite    // requer confirmação manual todo mês
  installments  // cria todas as parcelas de uma vez
}

enum NotificationType {
  invoice_due
  budget_alert
  recurring_pending
  promotion
  custom
}

// ─── Usuário ──────────────────────────────────────────────────────────────────
model User {
  id           String   @id @default(uuid())
  email        String   @unique
  name         String

  // passwordHash é opcional porque usuários OAuth não têm senha local.
  // O ? no final do tipo torna o campo nullable no banco (NULL permitido).
  passwordHash String?

  createdAt    DateTime @default(now())
  updatedAt    DateTime @updatedAt

  // Relações — o Prisma usa isso para gerar JOINs e garantir integridade referencial.
  transactions       Transaction[]
  categories         Category[]
  budgets            Budget[]
  recurringItems     RecurringTransaction[]
  notifications      Notification[]
  creditCards        CreditCard[]
  refreshTokens      RefreshToken[]
  oauthAccounts      OAuthAccount[]         // novo: identidades OAuth vinculadas
}

// ─── OAuth ────────────────────────────────────────────────────────────────────
// Separa a identidade OAuth do usuário.
// Um usuário pode ter múltiplas contas vinculadas (Google + GitHub).
// providerAccountId é o ID que o Google/GitHub usa internamente.
model OAuthAccount {
  id                String   @id @default(uuid())
  provider          String   // "google" | "github"
  providerAccountId String   // ID do usuário no provedor
  userId            String
  createdAt         DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  // Garante que um provedor não tenha o mesmo ID duplicado
  @@unique([provider, providerAccountId])
  @@index([userId])
}

// ─── Refresh Token ────────────────────────────────────────────────────────────
// Persiste refresh tokens para poder revogá-los e detectar roubo.
// usedAt: preenchido quando o token é trocado por um novo par (rotação).
// revokedAt: preenchido quando detectamos reuse (segurança) ou logout.
model RefreshToken {
  id        String    @id @default(uuid())
  token     String    @unique
  userId    String
  expiresAt DateTime
  usedAt    DateTime? // null = ainda válido para uso
  revokedAt DateTime? // null = não revogado
  createdAt DateTime  @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([token])
}

// ─── Categoria ────────────────────────────────────────────────────────────────
model Category {
  id     String @id @default(uuid())
  slug   String // ex: "moradia" — usado em URLs e como chave estável
  name   String // ex: "Moradia" — exibido na UI
  icon   String // emoji: "🏠"
  color  String // hex: "#E8845A"
  userId String

  // deletedAt implementa soft delete: o registro permanece no banco
  // mas todas as queries filtram por deletedAt IS NULL.
  deletedAt DateTime?

  user          User          @relation(fields: [userId], references: [id], onDelete: Cascade)
  subcategories Subcategory[]
  transactions  Transaction[]
  budgets       Budget[]
  recurringItems RecurringTransaction[]

  // Dois usuários podem ter categorias com o mesmo slug, mas um usuário
  // não pode ter duas categorias com o mesmo slug.
  @@unique([slug, userId])
  @@index([userId])
}

model Subcategory {
  id         String    @id @default(uuid())
  slug       String
  name       String
  icon       String
  categoryId String
  deletedAt  DateTime?

  category     Category      @relation(fields: [categoryId], references: [id], onDelete: Cascade)
  transactions Transaction[]
  budgets      Budget[]

  @@unique([slug, categoryId])
  @@index([categoryId])
}

// ─── Transação ────────────────────────────────────────────────────────────────
// Decimal(12, 2) armazena até 9.999.999.999,99 com precisão exata.
// NUNCA use Float para dinheiro — arredondamentos de ponto flutuante
// causam erros centavos que se acumulam ao longo do tempo.
model Transaction {
  id            String    @id @default(uuid())
  description   String
  amount        Decimal   @db.Decimal(12, 2)
  type          TxType
  date          DateTime
  notes         String?
  userId        String
  categoryId    String
  subcategoryId String?
  deletedAt     DateTime? // soft delete

  // Idempotência: guarda a chave enviada pelo frontend para evitar duplicatas
  // em caso de duplo clique ou retry de rede.
  idempotencyKey String? @unique

  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category     Category     @relation(fields: [categoryId], references: [id])
  subcategory  Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Índices compostos: o banco usa (userId, date) para todas as queries
  // de listagem e dashboard. Os demais aceleram os filtros mais comuns da UI.
  @@index([userId, date])
  @@index([userId, categoryId])
  @@index([userId, type])
  @@index([userId, deletedAt])
}

// ─── Orçamento ────────────────────────────────────────────────────────────────
// month usa o formato "YYYY-MM" (ex: "2026-03").
// Limitação conhecida: não permite queries de range facilmente.
// Aceitável no MVP — documentado como dívida técnica.
model Budget {
  id            String   @id @default(uuid())
  amount        Decimal  @db.Decimal(12, 2)
  month         String   // "YYYY-MM"
  userId        String
  categoryId    String?
  subcategoryId String?

  user        User         @relation(fields: [userId], references: [id], onDelete: Cascade)
  category    Category?    @relation(fields: [categoryId], references: [id])
  subcategory Subcategory? @relation(fields: [subcategoryId], references: [id])

  // Garante um orçamento por categoria/subcategoria por mês por usuário
  @@unique([userId, categoryId, subcategoryId, month])
  @@index([userId])
}

// ─── Recorrentes ──────────────────────────────────────────────────────────────
model RecurringTransaction {
  id            String        @id @default(uuid())
  description   String
  amount        Decimal?      @db.Decimal(12, 2) // null = valor variável (confirmado manualmente)
  type          TxType
  frequency     Frequency
  dayOfMonth    Int           // 1-31: dia do mês em que o lançamento ocorre
  startDate     DateTime
  endDate       DateTime?
  active        Boolean       @default(true)
  lastCreatedAt DateTime?     // última vez que gerou uma transação
  mode          RecurringMode
  installments  Int?          // total de parcelas (só no modo installments)
  creditCardId  String?       // vinculado a cartão (opcional)
  userId        String
  categoryId    String
  subcategoryId String?

  user     User        @relation(fields: [userId], references: [id], onDelete: Cascade)
  category Category    @relation(fields: [categoryId], references: [id])

  @@index([userId, active])
}

// ─── Cartão de Crédito ────────────────────────────────────────────────────────
model CreditCard {
  id               String   @id @default(uuid())
  name             String   // ex: "Nubank"
  icon             String   @default("💳")
  color            String   @default("#5A8FE8")
  closingDay       Int      // dia do fechamento da fatura (1-31)
  dueDay           Int      // dia do vencimento (1-31)
  limit            Decimal? @db.Decimal(12, 2)
  active           Boolean  @default(true)
  notifyDaysBefore Int      @default(3) // alertar N dias antes do vencimento
  userId           String

  user         User                    @relation(fields: [userId], references: [id], onDelete: Cascade)
  transactions CreditCardTransaction[]
  invoices     CreditCardInvoice[]

  @@index([userId, active])
}

model CreditCardTransaction {
  id             String   @id @default(uuid())
  cardId         String
  description    String
  amount         Decimal  @db.Decimal(12, 2)
  date           DateTime
  invoiceMonth   String   // "YYYY-MM" — calculado com base no closingDay
  categoryId     String
  subcategoryId  String?
  userId         String
  idempotencyKey String?  @unique

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@index([cardId, invoiceMonth])
  @@index([userId])
}

model CreditCardInvoice {
  id            String    @id @default(uuid())
  cardId        String
  month         String    // "YYYY-MM"
  dueDate       DateTime
  totalAmount   Decimal   @db.Decimal(12, 2)
  paid          Boolean   @default(false)
  paidAt        DateTime?
  transactionId String?   // a Transaction gerada quando a fatura foi paga
  userId        String

  card CreditCard @relation(fields: [cardId], references: [id], onDelete: Cascade)

  @@unique([cardId, month])
  @@index([userId])
}

// ─── Notificações ─────────────────────────────────────────────────────────────
model Notification {
  id          String           @id @default(uuid())
  userId      String
  type        NotificationType
  title       String
  message     String
  read        Boolean          @default(false)
  data        Json?            // payload extra (ex: { cardId, invoiceMonth })
  scheduledAt DateTime?
  createdAt   DateTime         @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, read])
  @@index([userId, createdAt])
}
